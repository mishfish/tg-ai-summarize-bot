# === Telegram Bot ===
TELEGRAM_TOKEN=your_bot_token_here
AUTH_CODE=your_secret_code_here  # users must send this to access the bot

# === Telethon (your personal Telegram account to read channels) ===
# Get API_ID and API_HASH from https://my.telegram.org
API_ID=12345678
API_HASH=your_api_hash_here
PHONE=+1234567890  # your phone number (optional, will prompt if missing)

# === LLM Provider ===
LLM_PROVIDER=groq  # "groq" or "anthropic"

GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-sonnet-4-6

# === Behavior ===
SYSTEM_PROMPT=You are a helpful assistant.
MAX_HISTORY=20
TEMPERATURE=0.7
MAX_TOKENS=2048
MAX_MESSAGES_PER_CHANNEL=500

# === Scheduled Summary ===
SUMMARY_TIME=09:00          # UTC time for daily digest
SUMMARY_CHAT_ID=0           # your Telegram user ID or group ID to receive digests
                            # get your ID by messaging @userinfobot

# === Alert Reposting ===
ALERT_TARGET_CHAT_ID=0      # channel ID where the bot reposts alert messages
                            # bot must be admin there (e.g. -1001234567890)
